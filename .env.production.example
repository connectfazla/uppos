# Copy to .env.production on the VPS (same directory as docker-compose.yml).
# Never commit .env.production.

# Supabase project (cloud OR self-hosted Kong/API URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only if you add server routes that use the service role
# SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (for redirects / absolute links if you extend the app)
NEXT_PUBLIC_SITE_URL=https://os.uppcore.tech
