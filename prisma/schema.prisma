generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM
  CLIENT
}

enum ClientStatus {
  LEAD
  ACTIVE
  PAUSED
  INACTIVE
}

enum RetainerStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  fullName       String?
  role           UserRole  @default(TEAM)
  clientId       String?
  portalOrg      Client?   @relation("ClientPortalUsers", fields: [clientId], references: [id], onDelete: SetNull)
  clientsManaged Client[]  @relation("ClientAccountManager")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Client {
  id                String        @id @default(uuid())
  companyName       String
  status            ClientStatus  @default(LEAD)
  notes             String?
  assignedManagerId String?
  accountManager    User?         @relation("ClientAccountManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  portalUsers       User[]        @relation("ClientPortalUsers")
  createdAt         DateTime      @default(now())
  archivedAt        DateTime?
  contacts          Contact[]
  retainers         Retainer[]
  contracts         Contract[]
  invoices          Invoice[]
}

model Contact {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  createdAt DateTime @default(now())
}

model Retainer {
  id               String              @id @default(uuid())
  clientId         String
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  monthlyFee       Decimal             @db.Decimal(12, 2)
  startDate        DateTime            @db.Date
  renewalDate      DateTime            @db.Date
  billingCycle     String              @default("monthly")
  status           RetainerStatus      @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deliverables     RetainerDeliverable[]
  contracts        Contract[]
  invoices         Invoice[]
}

model RetainerDeliverable {
  id             String   @id @default(uuid())
  retainerId     String
  retainer       Retainer @relation(fields: [retainerId], references: [id], onDelete: Cascade)
  platform       String
  numberOfPosts  Int      @default(0)
  campaigns      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
}

model Contract {
  id           String    @id @default(uuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  retainerId   String?
  retainer     Retainer? @relation(fields: [retainerId], references: [id], onDelete: SetNull)
  storagePath  String
  originalName String
  mimeType     String    @default("application/pdf")
  signedStatus String    @default("unsigned")
  signedDate   DateTime? @db.Date
  createdAt    DateTime  @default(now())
}

model Invoice {
  id          String        @id @default(uuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  retainerId  String?
  retainer    Retainer?     @relation(fields: [retainerId], references: [id], onDelete: SetNull)
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime      @db.Date
  status      InvoiceStatus @default(UNPAID)
  invoiceLink String
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payments    Payment[]
}

model Payment {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountPaid     Decimal  @db.Decimal(12, 2)
  paymentDate    DateTime @db.Date
  method         String   @default("bank_transfer")
  referenceNote  String?
  createdAt      DateTime @default(now())
}
